s = input()
t = '_' + '_'.join(s) + '_'
n = len(t)
p = [0] * n
c = 0
r = 0
for i in range(n):
    if i < r:
        p[i] = min(r - i, p[2*c - i])
    while i - p[i] - 1 >= 0 and i + p[i] + 1 < n and t[i - p[i] - 1] == t[i + p[i] + 1]:
        p[i] += 1
    if i + p[i] > r:
        c = i
        r = i + p[i]           
ans = 0
for x in p:
    ans += (x + 1) // 2
print(ans)
